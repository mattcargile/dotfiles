# No Op for *nix because files are in correct location already {{- if eq .chezmoi.os "windows" }}
[CmdletBinding(SupportsShouldProcess, ConfirmImpact = 'Medium')]
param()
# PowerShell\profile.ps1 SHA256: {{ include ( joinPath .chezmoi.destDir "Documents" "PowerShell" "profile.ps1" ) | sha256sum }}
# WindowsPowerShell\profile.ps1 SHA256: {{ include ( joinPath .chezmoi.destDir "Documents" "WindowsPowerShell" "profile.ps1" ) | sha256sum }}
# chezmoi get PowerShell actual profile {{- $profileCorePath := output "pwsh" "-NoLogo" "-NoProfile" "-Command" "$PROFILE.CurrentUserAllHosts" | trim }}
# chezmoi get maybe OneDrive dir. profile.ps1 -> PowerShell -> Documents -> OneDrive {{- $profileCoreMaybeOneDriveFolderName := osBase ( osDir ( osDir ( osDir $profileCorePath ) ) ) }}
# chezmoi if OneDrive {{- if hasPrefix "OneDrive" $profileCoreMaybeOneDriveFolderName }}
# chezmoi get WindowsPowerShell actual profile {{- $profileDesktopPath := output "powershell" "-NoProfile" "-Command" "$PROFILE.CurrentUserAllHosts" | trim }}
# PowerShell Actual Profile SHA256: {{ include $profileCorePath | sha256sum }}
# WindowsPowerShell Actual Profile SHA256: {{ include $profileDesktopPath | sha256sum }}
# chezmoi end if OneDrive {{- end }}

$ErrorActionPreference = 'Stop'
Set-StrictMode -Version Latest

$profileCoreRelativePath = Join-Path Documents PowerShell profile.ps1
$profileDesktopRelativePath = Join-Path Documents WindowsPowerShell profile.ps1
$profileFilePath = Join-Path $env:USERPROFILE $profileCoreRelativePath
$profileDesktopFilePath = Join-Path $env:USERPROFILE $profileDesktopRelativePath
$myDocumentsParentPath = Split-Path -Path $( [Environment]::GetFolderPath('MyDocuments') ) -Parent
Write-Verbose -Message "MyDocuments Parent Path: $myDocumentsParentPath"
$oneDriveRedirectPathWildcard = "$( Join-Path -Path $env:USERPROFILE -ChildPath 'OneDrive' )*"
Write-Verbose -Message "User Profile OneDrive wild card pattern: $oneDriveRedirectPathWildcard"
if ($myDocumentsParentPath -like $oneDriveRedirectPathWildcard) {
    if ($env:OneDriveCommercial) {
        $profileCoreCommDestination = Join-Path $env:OneDriveCommercial $profileCoreRelativePath
        if ($PSCmdlet.ShouldProcess( $profileFilePath, "Copy to Core Commercial location, $profileCoreCommDestination.")) {
            Copy-Item -Path $profileFilePath -Destination $profileCoreCommDestination
        }
        $profileDeskCommDestination = Join-Path $env:OneDriveCommercial $profileDesktopRelativePath
        if ($PSCmdlet.ShouldProcess( $profileDesktopFilePath, "Copy to Desktop Commercial location, $profileDeskCommDestination.")) {
            Copy-Item -Path $profileDesktopFilePath -Destination $profileDeskCommDestination
        }
    }
    if ($env:OneDriveConsumer) {
        $profileCoreConsDestination = Join-Path $env:OneDriveConsumer $profileCoreRelativePath
        if ($PSCmdlet.ShouldProcess( $profileFilePath, "Copy to Core Consumer location, $profileCoreConsDestination")) {
            Copy-Item -Path $profileFilePath -Destination $profileCoreConsDestination
        }
        $profileDeskConsDestination = Join-Path $env:OneDriveConsumer $profileDesktopRelativePath
        if ($PSCmdlet.ShouldProcess( $profileDesktopFilePath, "Copy to Desktop Consumer location, $profileDeskConsDestination")) {
            Copy-Item -Path $profileDesktopFilePath -Destination $profileDeskConsDestination
        }
    }
}
# end {{- end }}
