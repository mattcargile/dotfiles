function Out-Paging {
    [Alias('op')]
    [CmdletBinding(PositionalBinding = $false)]
    param(
        [Parameter(ValueFromRemainingArguments = $true)]
        [string[]] $ArgumentList,

        [Parameter(ValueFromPipeline)]
        [psobject] $InputObject
    )
    begin {
        # chezmoi if isPSCore {{- if .isPSCore }}
        # chezmoi if paging available {{- if .isPagingAvailable }}
        $pipeOriginal = { TextMate\Out-Page }
        if (-not (Get-Module -Name TextMate)) {
            $pipeFallback = { Out-AnsiFormatting -Stream | less $env:LESS @ArgumentList }
            try {
                Import-Module -Name TextMate -ErrorAction Stop
            }
            catch [System.IO.FileLoadException] {
                Write-Warning 'Failed to import TextMate module due to file load and most likely dll incompatibilities. Falling back to use less pager.'
                $pipeOriginal = $pipeFallback
            }
            catch {
                Write-Warning "Failed to import TextMate module. $_"
                $pipeOriginal = $pipeFallback
            }
        }
        $pipe = $pipeOriginal.GetSteppablePipeline($MyInvocation.CommandOrigin)
        # chezmoi else paging not supported {{- else }}{{ nindent 8 "$pipe = { Out-AnsiFormatting -Stream | less $env:LESS @ArgumentList }.GetSteppablePipeline($MyInvocation.CommandOrigin)" }}
        # chezmoi if paging supported end {{- end }}
        # chezmoi else for desktop edition {{- else }}{{ nindent 8 "$pipe = { less $env:LESS @ArgumentList }.GetSteppablePipeline($MyInvocation.CommandOrigin)" }}
        # chezmoi if isPSCore end {{- end }}
        $pipe.Begin($PSCmdlet)
    }
    process {
        $pipe.Process($PSItem)
    }
    end {
        $pipe.End()
    }
}
