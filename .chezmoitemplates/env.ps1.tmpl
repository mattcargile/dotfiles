{{- /*
Set Environment variables for fzf binary progam includes dependency on bat and fd
Note on performance: --color=always on fd using --ansi on fzf is too slow for over 100k files. It is the 
--ansi flag that ultimately slows it down.
Note on file attributes: --hidden --exclude .git can be used to see hidden files and exclude .git. --no-ignore
has to be used in order to find files within the .gitignore file. By default fd doesn't show these files.
*/ -}}
{{- /* Has interplay with `$env:SHELL`. Requires `cmd.exe`. */ -}}
$env:FZF_DEFAULT_COMMAND = 'fd.exe'
{{/* -1 is default terminal color. Hexcodes derived from oh-my-posh config.
gutter's color implementation changed along the lines and the default didn't work and produces and ugly white bar so hard coding to Dracula (Official) wezterm background
So VSCode may not look as nice. */ -}}
{{- $fzfGutterColor := "if ($env:TERM_PROGRAM -eq 'vscode' -and $Host.Name -eq 'Visual Studio Code Host') { '#181818' <# Default Dark Modern ( Found with Color Picker in PowerToys ) #> } else { '#282a36' <# Dracula (Official) Background #> }" -}}
{{- $fzfTheme := printf "--color='hl+:#5fd7ff,hl:#5f87af,bg:-1,bg+:-1,fg:-1,fg+:#919092,gutter:$(%s)" $fzfGutterColor -}}
{{- $fzfIconTheme := "--color='prompt:#00897b,pointer:#c386f1,marker:#ff479c'" -}}
{{- $fzfIcons := "--prompt='\uF054 ' --pointer='\U000f070b ' --marker='\uF444'" -}}
{{- $fzfLayout := "--border=rounded --padding=1 --margin=1" -}}
{{- $fzfHistory := printf "--history='%s'" ( joinPath .homeDir ".config" "fzf" ".fzf_history" ) -}}
{{- /* Go to first item upon key entry change */ -}}
{{- $fzfBind := "--bind change:first" -}}
{{- $fzfOpts := printf "%s %s %s %s %s %s" $fzfTheme $fzfIconTheme $fzfIcons $fzfLayout $fzfHistory $fzfBind -}}
$env:FZF_DEFAULT_OPTS = "{{- $fzfOpts -}}"
{{/*
PsFzf module. 
Below parameter is default for fzf. If want to avoid using $env:FZF_DEFAULT_OPTS
*/ -}}
$env:_PSFZF_FZF_DEFAULT_OPTS = ''
$env:FZF_CTRL_T_COMMAND = ''
$env:FZF_CTRL_T_OPTS = ''
$env:FZF_ALT_C_COMMAND = 'fd.exe --type directory'
$env:FZF_ALT_C_OPTS = ''
$env:FZF_CTRL_R_OPTS = ''
{{/* User level environment variable. Not sure how it was configured. */ -}}
{{- if eq .os "windows" -}}
$env:ChocolateyToolsLocation = 'C:\tools'
{{ end -}}
{{- /* carapace completions use PSReadLine tooltip */}}
$env:CARAPACE_TOOLTIP = 1
{{/* Allows `pwsh` `help` function to use nicer pager program than `more` for easier paging */ -}}
$env:PAGER = 'less'
{{- $lessDefaultParams := "--raw-control-chars --ignore-case --quit-if-one-screen --quiet" -}}
{{- /* Options which are passed to less.exe automatically. */}}
$env:LESS = {{ $lessDefaultParams | squote }}
$env:LESSHISTFILE = {{ joinPath .homeDir "_lesshst" | squote }}
$env:LESSCHARSET = 'utf-8'
{{/* Read by less.exe. Otherwise vi is the default. EDITOR is used also but not sure if other applications use this variable. */ -}}
$env:VISUAL = 'code'
{{/* If line number is known, go to it. Otherwise open the file. */ -}}
$env:LESSEDIT = '%E ?l--goto %g\:%l:%g.'
{{/* Read by git.exe. If not set, `$env:VISUAL` is used instead and 'code.cmd' exits prematurely with an empty commit. */ -}}
$env:GIT_EDITOR = 'nvim'
{{/* lf.exe Terminal File Manager */ -}}
{{- /* e key mapping */ -}}
$env:EDITOR = 'code'
{{/* w key mapping. Need to use cmd.exe for fzf DEFAULT_COMMAND to work. */ -}}
$env:SHELL = 'cmd.exe'
$env:RIPGREP_CONFIG_PATH = {{ joinPath .homeDir ".config" "ripgrep" ".ripgreprc" | squote }}
$env:BAT_THEME = 'Visual Studio Dark+'
$env:BAT_PAGER = {{ printf "less %s" $lessDefaultParams | squote }}
$env:PSModulePath += {{ printf "%s%s" .pathListSeparator ( joinPath .homeDir ".config" "powershell" "MyProfile" ) | squote }}
{{ if lookPath "/home/linuxbrew/.linuxbrew/bin/brew" }}
{{ output "pwsh" "-NoProfile" "-NoLogo" "-Command" (joinPath .destDir ".." "linuxbrew" ".linuxbrew" "bin" "brew" ) "shellenv" "pwsh" -}}
{{- end }}
