function Set-MyOmpContext {
    param([bool]$originalStatus)
{{- /* Helper for relative pathing on dotnet methods. They use the process level path. */}}
    [System.Environment]::CurrentDirectory = (Get-Location -PSProvider FileSystem).ProviderPath
{{- /* Ensure nvim exited shells are in Insert Mode Steady bar cursor shape. With wezterm and Windows Terminal the default appears to be a block. nvim may be reseting and terminals aren't handling well. */}}
    if ([Microsoft.PowerShell.PSConsoleReadLine]::InViInsertMode()) {
{{- /* Steady bar cursor shape */}}
        [Console]::Write("$([char]0x1B)[6 q")
    }
}
{{/*
   * scoop runs `Set-Alias` on every call
   * Want to prevent it from setting this over and over and causing `$WhatIfPreference = $true` to trigger
   * https://github.com/ScoopInstaller/Scoop/pull/4794
   * https://github.com/ScoopInstaller/Scoop/blob/b588a06e41d920d2123ec70aee682bae14935939/bin/scoop.ps1#L11-L15
   */}}
Set-Alias -Name 'Set-PoshContext' -Value 'Set-MyOmpContext' -Option ReadOnly -Force
oh-my-posh @(
    'init'
    'pwsh'
    '--config'
    {{ joinPath .homeDir ".config" "oh-my-posh" "night-owl_mac.omp.json" | squote }}
) | Invoke-Expression
