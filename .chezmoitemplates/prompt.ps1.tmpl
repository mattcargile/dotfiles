# chezmoi HomeBrew Shell Env if block {{ if lookPath "/home/linuxbrew/.linuxbrew/bin/brew" }}
& /home/linuxbrew/.linuxbrew/bin/brew shellenv | Invoke-Expression
# end {{ end }}
# Want to avoid running heavier code in `gsudo`, `pwsh -c`, or other non-`function:\prompt` executing contexts
function prompt {

    {{ includeTemplate "readlineoptionprediction.ps1.tmpl" . }}
    {{ includeTemplate "readlinekeyhandler.ps1" . }}

    # Custom OMP Prompt Context
    function global:Set-MyOmpContext {
        [Alias('Set-PoshContext')]
        param()
        # Update process level directory. Helps with .Net Methods.
        [System.Environment]::CurrentDirectory = (Get-Location -PSProvider FileSystem).ProviderPath
    }

    oh-my-posh init pwsh --config "$([System.IO.Path]::Combine( $HOME, '.config', 'oh-my-posh', 'night-owl_mac.omp.json' ))" | Invoke-Expression
    prompt # For first initial run or else prompt is "empty"
}

